{
  "name": "amb-app",
  "packageManager": "pnpm@10.19.0",
  "version": "1.2.4",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bizmedia/amb.git"
  },
  "homepage": "https://github.com/bizmedia/amb#readme",
  "author": "Anatoliy Tukov <openaisdk@gmail.com>",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "msw",
      "prisma"
    ]
  },
  "scripts": {
    "postinstall": "sh scripts/chmod-node-bin.sh",
    "scripts:help": "node scripts/print-scripts-help.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "fix:bin": "sh scripts/chmod-node-bin.sh",
    "dev": "turbo run dev --filter=amb-web --filter=amb-api",
    "dev:api": "pnpm --filter amb-api run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "start": "turbo run start --filter=amb-web",
    "lint": "turbo run lint --filter=amb-web",
    "db:migrate": "pnpm --filter @amb-app/db run db:migrate",
    "db:migrate:deploy": "pnpm --filter @amb-app/db run db:migrate:deploy",
    "db:studio": "pnpm --filter @amb-app/db run db:studio",
    "backup:db": "./scripts/backup/postgres-backup.sh",
    "restore:db": "./scripts/backup/postgres-restore.sh",
    "seed:agents": "pnpm --filter amb-web run seed:agents",
    "seed:threads": "pnpm --filter amb-web run seed:threads",
    "seed:all": "pnpm --filter amb-web run seed:all",
    "example:simple": "pnpm --filter amb-web run example:simple",
    "example:inbox": "pnpm --filter amb-web run example:inbox",
    "example:workflow": "pnpm --filter amb-web run example:workflow",
    "orchestrator": "pnpm --filter amb-web run orchestrator",
    "mcp:build": "turbo run build --filter=@openaisdk/amb-mcp",
    "mcp:dev": "pnpm --filter @openaisdk/amb-mcp run dev",
    "agent:worker": "pnpm --filter amb-web run agent:worker",
    "agent:worker:single": "pnpm --filter amb-web run agent:worker:single",
    "po:check-inbox": "pnpm --filter amb-web run po:check-inbox",
    "deploy:amb": "sh scripts/deploy/up-published-stack.sh",
    "deploy:dev:db": "podman compose -f docker-compose.dev.yml up -d postgres",
    "deploy:dev:db:down": "podman compose -f docker-compose.dev.yml down",
    "deploy:local": "bash -c 'export WEB_PORT=4333 API_PORT=4334; podman compose up -d --build && bash scripts/wait-for-local-stack.sh'",
    "deploy:local:standalone": "bash -c 'export WEB_PORT=3333 API_PORT=3334; podman compose up -d --build && bash scripts/wait-for-local-stack.sh'",
    "deploy:local:down": "podman compose down -v",
    "deploy:prod": "./scripts/deploy/production-deploy.sh",
    "deploy:k8s:migrate": "kubectl apply -f deploy/k8s/api-migrate-job.yaml",
    "deploy:k8s:api": "kubectl apply -f deploy/k8s/api-deployment.yaml -f deploy/k8s/api-service.yaml"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.16",
    "shadcn": "^3.7.0",
    "tailwindcss": "^4",
    "turbo": "^2.5.4",
    "tw-animate-css": "^1.4.0"
  }
}
