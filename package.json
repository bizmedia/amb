{
  "name": "amb-app",
  "packageManager": "pnpm@10.19.0",
  "version": "0.1.2",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bizmedia/amb.git"
  },
  "homepage": "https://github.com/bizmedia/amb#readme",
  "author": "Анатолий Туков <anatoliy.tukov@gmail.com>",
  "scripts": {
    "dev": "turbo run dev --filter=mcp-message-bus",
    "build": "turbo run build",
    "start": "turbo run start --filter=mcp-message-bus",
    "lint": "turbo run lint --filter=mcp-message-bus",
    "db:migrate": "pnpm --filter @amb-app/db run db:migrate",
    "db:migrate:deploy": "pnpm --filter @amb-app/db run db:migrate:deploy",
    "db:studio": "pnpm --filter @amb-app/db run db:studio",
    "seed:agents": "pnpm --filter mcp-message-bus run seed:agents",
    "seed:threads": "pnpm --filter mcp-message-bus run seed:threads",
    "seed:all": "pnpm --filter mcp-message-bus run seed:all",
    "reset-db": "pnpm --filter mcp-message-bus run reset-db",
    "worker:retry": "pnpm --filter mcp-message-bus run worker:retry",
    "cleanup": "pnpm --filter mcp-message-bus run cleanup",
    "example:simple": "pnpm --filter mcp-message-bus run example:simple",
    "example:inbox": "pnpm --filter mcp-message-bus run example:inbox",
    "example:workflow": "pnpm --filter mcp-message-bus run example:workflow",
    "orchestrator": "pnpm --filter mcp-message-bus run orchestrator",
    "mcp:build": "turbo run build --filter=@openaisdk/amb-mcp",
    "mcp:dev": "pnpm --filter @openaisdk/amb-mcp run dev",
    "agent:worker": "pnpm --filter mcp-message-bus run agent:worker",
    "agent:worker:single": "pnpm --filter mcp-message-bus run agent:worker:single",
    "po:check-inbox": "pnpm --filter mcp-message-bus run po:check-inbox",
    "docker:compose:publish": "podman build -t docker.io/openaisdk/amb:latest . && podman push docker.io/openaisdk/amb:latest",
    "deploy:amb": "podman pull docker.io/openaisdk/amb:latest && podman compose up -d",
    "mcp:publish": "pnpm mcp:build && cd packages/mcp-server && npm publish --access public",
    "mcp:version": "cd packages/mcp-server && npm version"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
