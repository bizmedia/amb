{
  "name": "mcp-message-bus",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bizmedia/amb.git"
  },
  "homepage": "https://github.com/bizmedia/amb#readme",
  "author": "Анатолий Туков <anatoliy.tukov@gmail.com>",
  "scripts": {
    "dev": "echo '' && echo '  API Docs (Swagger): http://localhost:3333/api-docs' && echo '' && next dev -p 3333",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start -p 3333",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "seed:agents": "tsx --env-file .env scripts/seed-agents.ts",
    "seed:threads": "tsx --env-file .env scripts/seed-threads.ts",
    "seed:all": "pnpm seed:agents && pnpm seed:threads",
    "reset-db": "tsx --env-file .env scripts/reset-db.ts",
    "worker:retry": "tsx --env-file .env scripts/retry-worker.ts",
    "cleanup": "tsx --env-file .env scripts/cleanup.ts",
    "example:simple": "tsx --env-file .env examples/simple-agent.ts",
    "example:inbox": "tsx --env-file .env examples/inbox-listener.ts",
    "example:workflow": "tsx --env-file .env examples/workflow-runner.ts",
    "orchestrator": "tsx --env-file .env scripts/orchestrator.ts",
    "mcp:build": "cd mcp-server && pnpm build",
    "mcp:dev": "cd mcp-server && pnpm dev",
    "agent:worker": "tsx --env-file .env scripts/agent-worker.ts",
    "agent:worker:single": "tsx --env-file .env scripts/agent-worker.ts --agent-id=",
    "po:check-inbox": "tsx --env-file .env scripts/po-inbox-checker.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.5",
    "pg": "^8.17.2",
    "prisma": "^7.3.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-json-view-lite": "^2.5.0",
    "shadcn": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
