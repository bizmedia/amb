{
  "project": "agent-message-bus-local",
  "mode": "local-dev",
  "description": "Local-only multi-agent setup for Next.js Agent Message Bus",
  "agents": [
    {
      "id": "po",
      "name": "Product Owner",
      "role": "po",
      "systemPromptFile": ".cursor/agents/po.md",
      "defaultThreads": [
        "feature-definition",
        "backlog-review",
        "release-planning"
      ]
    },
    {
      "id": "architect",
      "name": "System Architect",
      "role": "architect",
      "systemPromptFile": ".cursor/agents/architect.md",
      "defaultThreads": [
        "architecture-review",
        "adr-discussion",
        "scaling-path"
      ]
    },
    {
      "id": "dev",
      "name": "Developer",
      "role": "dev",
      "systemPromptFile": ".cursor/agents/dev.md",
      "defaultThreads": [
        "implementation",
        "bugfix",
        "refactor"
      ]
    },
    {
      "id": "qa",
      "name": "QA Engineer",
      "role": "qa",
      "systemPromptFile": ".cursor/agents/qa.md",
      "defaultThreads": [
        "qa-cycle",
        "release-validation",
        "dlq-tests"
      ]
    },
    {
      "id": "devops",
      "name": "DevOps Engineer",
      "role": "devops",
      "systemPromptFile": ".cursor/agents/devops.md",
      "defaultThreads": [
        "local-setup",
        "infra-fixes"
      ]
    },
    {
      "id": "sdk",
      "name": "SDK Developer",
      "role": "sdk",
      "systemPromptFile": ".cursor/agents/sdk.md",
      "defaultThreads": [
        "sdk-dev",
        "mcp-integration",
        "api-contract"
      ]
    },
    {
      "id": "ux",
      "name": "UX Designer",
      "role": "ux",
      "systemPromptFile": ".cursor/agents/ux.md",
      "defaultThreads": [
        "ux-review",
        "interaction-design",
        "usability-fixes"
      ]
    },
    {
      "id": "orchestrator",
      "name": "Workflow Orchestrator",
      "role": "orchestrator",
      "systemPromptFile": ".cursor/agents/orchestrator.md",
      "defaultThreads": [
        "feature-workflow",
        "release-orchestration",
        "incident-response"
      ]
    },
    {
      "id": "tech-writer",
      "name": "Technical Writer",
      "role": "tech-writer",
      "systemPromptFile": ".cursor/agents/tech-writer.md",
      "defaultThreads": [
        "documentation",
        "api-docs",
        "runbook",
        "onboarding",
        "release-notes"
      ]
    },
    {
      "id": "open-source",
      "name": "Open Source & Community",
      "role": "open-source",
      "systemPromptFile": ".cursor/agents/open-source.md",
      "defaultThreads": [
        "open-source-readiness",
        "contributing-and-coc",
        "community-and-promotion",
        "release-and-changelog"
      ]
    },
    {
      "id": "nest-engineer",
      "name": "Senior Nest.js Engineer",
      "role": "nest-engineer",
      "systemPromptFile": ".cursor/agents/nest-engineer.md",
      "defaultThreads": [
        "api-implementation",
        "api-refactor",
        "nest-patterns"
      ]
    },
    {
      "id": "react-next-engineer",
      "name": "Senior React + Next.js Engineer",
      "role": "react-next-engineer",
      "systemPromptFile": ".cursor/agents/react-next-engineer.md",
      "defaultThreads": [
        "frontend-implementation",
        "ui-components",
        "next-optimization"
      ]
    }
  ],
  "defaults": {
    "threadRetentionDays": 30,
    "maxRetries": 5,
    "pollIntervalSeconds": 5
  }
}
