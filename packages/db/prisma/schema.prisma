datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../src/generated"
  moduleFormat = "cjs"
}
model Agent {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  role         String
  status       String   @default("online")
  capabilities Json?

  createdAt DateTime @default(now())
  lastSeen  DateTime?
  issuesAssigned Issue[] @relation("IssueAssignee")

  @@index([projectId])
}

model Thread {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  status    String   @default("open")
  createdAt DateTime @default(now())

  messages Message[]

  @@index([projectId])
}

model Message {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  threadId String
  thread   Thread @relation(fields: [threadId], references: [id])

  fromAgentId String
  toAgentId   String?

  payload Json

  status  String @default("pending")
  retries Int    @default(0)

  parentId String?
  parent   Message? @relation("Replies", fields: [parentId], references: [id])
  replies  Message[] @relation("Replies")

  createdAt DateTime @default(now())

  @@index([threadId])
  @@index([projectId])
  @@index([toAgentId])
  @@index([fromAgentId])
  @@index([status])
  @@index([createdAt])
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  projects Project[]
}

model Project {
  id        String   @id @default(uuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  agents   Agent[]
  threads  Thread[]
  messages Message[]
  issues   Issue[]

  @@index([tenantId])
}

enum IssueState {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum IssuePriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Issue {
  id          String        @id @default(uuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  state       IssueState    @default(BACKLOG)
  priority    IssuePriority @default(NONE)
  assigneeId  String?
  assignee    Agent?        @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([projectId])
  @@index([state])
  @@index([priority])
  @@index([assigneeId])
  @@index([dueDate])
}
