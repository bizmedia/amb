{
  "name": "mcp-message-bus",
  "version": "0.1.2",
  "private": true,
  "scripts": {
    "dev": "echo '' && echo '  API Docs (Swagger): http://localhost:3333/api-docs' && echo '' && next dev -p 3333",
    "build": "next build",
    "postinstall": "pnpm --filter @amb-app/db exec prisma generate",
    "start": "next start -p 3333",
    "lint": "eslint",
    "db:migrate": "pnpm --filter @amb-app/db run db:migrate",
    "db:migrate:deploy": "pnpm --filter @amb-app/db run db:migrate:deploy",
    "db:studio": "pnpm --filter @amb-app/db run db:studio",
    "seed:agents": "tsx scripts/seed-agents.ts",
    "seed:threads": "tsx scripts/seed-threads.ts",
    "seed:all": "pnpm seed:agents && pnpm seed:threads",
    "reset-db": "tsx scripts/reset-db.ts",
    "worker:retry": "tsx scripts/retry-worker.ts",
    "cleanup": "tsx scripts/cleanup.ts",
    "example:simple": "tsx examples/simple-agent.ts",
    "example:inbox": "tsx examples/inbox-listener.ts",
    "example:workflow": "tsx examples/workflow-runner.ts",
    "orchestrator": "tsx scripts/orchestrator.ts",
    "agent:worker": "tsx scripts/agent-worker.ts",
    "agent:worker:single": "tsx scripts/agent-worker.ts --agent-id=",
    "po:check-inbox": "tsx scripts/po-inbox-checker.ts"
  },
  "dependencies": {
    "@amb-app/db": "workspace:*",
    "@amb-app/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "lucide-react": "^0.563.0",
    "next": "16.1.5",
    "next-intl": "^4.8.3",
    "pg": "^8.17.2",
    "prisma": "^7.3.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "react-json-view-lite": "^2.5.0",
    "react-markdown": "^10.1.0",
    "shadcn": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
