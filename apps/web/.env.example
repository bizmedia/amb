# Postgres с хоста: см. apps/api/.env.example — для `pnpm deploy:dev:db` порт 5434, для полного compose — 5433.
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/amb
MESSAGE_BUS_URL=http://localhost:3333