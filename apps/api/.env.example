# С Postgres из docker compose (см. docker-compose.yml) с хоста используйте порт 5433, не 5432.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/amb
JWT_SECRET=change-me-for-local-dev

# Rate limit: запросов на бакет (tenant+project+ip+method) за окно. 0 = отключить. По умолчанию 20000/мин.
# RATE_LIMIT_MAX_REQUESTS=20000
# RATE_LIMIT_WINDOW_MS=60000
